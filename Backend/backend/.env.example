# ─── Server ────────────────────────────────────────
NODE_ENV=development
PORT=5000

# ─── MySQL Database ────────────────────────────────
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=botforge_dev
DB_USER=root
DB_PASSWORD=your_password
DB_SSL=false
MYSQL_ROOT_PASSWORD=root_password

# ─── Optional Postgres / Neon Database ──────────────
# When using Neon, set DATABASE_URL instead of the MySQL vars.
# Example: DATABASE_URL=postgresql://<user>:<password>@<host>:<port>/<database>?sslmode=require
DATABASE_URL=

# ─── Redis ─────────────────────────────────────────
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

# ─── JWT Secrets ───────────────────────────────────
JWT_SECRET=your_jwt_secret
JWT_REFRESH_SECRET=your_jwt_refresh_secret
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── LLM Provider ──────────────────────────────────
# Options: gemini, openai, anthropic
LLM_PROVIDER=gemini
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-1.5-flash
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ─── Rate Limiting ─────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
AUTH_RATE_LIMIT_MAX=20
CHAT_RATE_LIMIT_MAX=60

# ─── CORS ──────────────────────────────────────────
CORS_ORIGIN=*

# ─── Billing ───────────────────────────────────────
BILLING_WEBHOOK_SECRET=your_webhook_secret
