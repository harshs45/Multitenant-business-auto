# =========================
# Application Config
# =========================
PORT=5000
NODE_ENV=production

# =========================
# MySQL Database Config
# NOTE: In Docker, DB_HOST must be the service name 'mysql'
# =========================
DB_HOST=mysql
DB_PORT=3306
DB_NAME=botforge_prod
DB_USER=root
DB_PASSWORD=your_secure_db_password

# =========================
# Redis Config
# NOTE: In Docker, REDIS_HOST must be the service name 'redis'
# =========================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# =========================
# Security
# =========================
JWT_SECRET=replace_this_with_a_long_random_secure_string

# =========================
# External APIs
# =========================
GEMINI_API_KEY=your_gemini_api_key_here
